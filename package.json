{
  "name": "@sleepinsummer/agent-browser-cli",
  "version": "0.3.1-beta.1",
  "description": "Agent-oriented browser sensing and control CLI backed by a native Rust daemon.",
  "license": "MIT",
  "bin": {
    "agent-browser-cli": "npm/bin/agent-browser-cli.js"
  },
  "files": [
    "npm/bin",
    "npm/postinstall.js",
    "assets",
    "skills",
    "README.md",
    "README_EN.md",
    "AI_INSTALL.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "cargo build --release",
    "version": "node scripts/sync-optional-deps.mjs && git add package.json package-lock.json",
    "prepack": "node scripts/sync-optional-deps.mjs",
    "postinstall": "node npm/postinstall.js"
  },
  "optionalDependencies": {
    "@sleepinsummer/agent-browser-cli-darwin-arm64": "0.3.1-beta.1",
    "@sleepinsummer/agent-browser-cli-darwin-x64": "0.3.1-beta.1",
    "@sleepinsummer/agent-browser-cli-linux-x64": "0.3.1-beta.1",
    "@sleepinsummer/agent-browser-cli-linux-arm64": "0.3.1-beta.1",
    "@sleepinsummer/agent-browser-cli-win32-x64": "0.3.1-beta.1"
  },
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/sleepinginsummer/agent-browser-cli"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
